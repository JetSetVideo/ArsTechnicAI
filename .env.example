# ─── ArsTechnicAI — Environment Template ───────────────────────────────────────
# Copy to .env.local and fill in real values.  Never commit .env.local.
#
# OFFLINE / STANDALONE MODE (Mode 1):
#   Only NEXTAUTH_URL and NEXTAUTH_SECRET are required.
#   Comment out DATABASE_URL and REDIS_URL to run without a database.
#
# LOCAL FULL-STACK MODE (Mode 2):
#   Uncomment DATABASE_URL and REDIS_URL, run `deno task prisma:push` once.
#
# CONNECTED TO UBUNTU SERVER (Mode 3):
#   Point DATABASE_URL / REDIS_URL at 192.168.1.55.

# ── App ──────────────────────────────────────────────────────────────────────
# Must match the port deno task dev binds to (always 3002)
NEXTAUTH_URL="http://localhost:3002"
# Generate with:  openssl rand -base64 32
NEXTAUTH_SECRET=""

NODE_ENV="development"
APP_PORT="3002"

# ── Database (optional — comment out for offline mode) ───────────────────────
# DATABASE_URL="postgresql://ars_user:<password>@localhost:5432/arstechnicai_dev"

# ── Redis (optional — comment out for offline mode) ──────────────────────────
# REDIS_URL="redis://localhost:6379"
# REDIS_PREFIX="arstechnicai:"

# ── OAuth providers (optional — add keys to enable social login) ──────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── AI providers — keys can also be entered in Settings → API Keys ────────────
GOOGLE_IMAGEN_API_KEY=""
OPENAI_API_KEY=""
STABILITY_API_KEY=""
REPLICATE_API_TOKEN=""
FAL_KEY=""
ELEVENLABS_API_KEY=""

# ── Encryption (generate with: openssl rand -hex 32) ─────────────────────────
ENCRYPTION_KEY=""

# ── File storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR="./storage/uploads"
THUMBNAIL_DIR="./storage/thumbnails"
PREVIEW_DIR="./storage/previews"
TEMP_DIR="./storage/temp"
MAX_FILE_SIZE_MB="500"

# ── Media processing ──────────────────────────────────────────────────────────
# ffmpeg is auto-detected per platform.  Override only if detection fails:
#   Ubuntu:  /usr/bin/ffmpeg
#   Mac M1:  /opt/homebrew/bin/ffmpeg   (brew install ffmpeg)
#   Mac x86: /usr/local/bin/ffmpeg
# FFMPEG_PATH=""
# FFPROBE_PATH=""

# ── Social publishing (OAuth tokens — added via Settings → Publishing) ─────────
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""

# ── Monitoring ────────────────────────────────────────────────────────────────
LOG_LEVEL="info"
SENTRY_DSN=""

# ── Embedding / vector search (used with pgvector) ───────────────────────────
EMBEDDING_PROVIDER="openai"
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIMENSIONS="1536"

# ── Job queue ─────────────────────────────────────────────────────────────────
JOB_QUEUE_MAX_CONCURRENT="3"
JOB_QUEUE_POLL_INTERVAL_MS="2000"
JOB_DEFAULT_TIMEOUT_MS="300000"
JOB_MAX_RETRIES="3"

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="60"
RATE_LIMIT_GENERATION_MAX="10"
