##
# Frontend <-> Backend bridge
#
# Keep this file as reference and copy values into .env.local
##

# Turn on external backend delegation in /api/generate
BACKEND_GENERATION_ENABLED=false

# Optional external backend health URL used by ConnectionBanner.
# Leave empty when using built-in Next.js API routes.
BACKEND_URL=

# Optional: proxy all /api/* from local frontend to a remote backend.
# Example (from Mac) -> Ubuntu host:
# API_PROXY_TARGET=http://192.168.1.10:3000
API_PROXY_TARGET=

# Optional custom path used by backend generation endpoint
# Final URL is resolved as: BACKEND_URL + BACKEND_GENERATION_PATH
BACKEND_GENERATION_PATH=/api/v1/generate

# Optional backend auth token (if your backend requires Bearer auth)
BACKEND_API_KEY=

# Optional direct provider keys (used when backend is disabled/fails)
ARSTECHNICAI_NANOBANANA_API_KEY=
