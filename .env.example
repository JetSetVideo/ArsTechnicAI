# DATABASE
DATABASE_URL="postgresql://arstechnicai:<password>@localhost:5432/arstechnicai?schema=public"

# NEXTAUTH
NEXTAUTH_URL="http://localhost:3002"
NEXTAUTH_SECRET="<openssl rand -base64 32>"

# OAUTH PROVIDERS
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# REDIS
REDIS_URL="redis://localhost:6379"
REDIS_PREFIX="arstechnicai:"

# AI PROVIDERS
GOOGLE_IMAGEN_API_KEY=""
OPENAI_API_KEY=""
STABILITY_API_KEY=""
MIDJOURNEY_API_KEY=""
REPLICATE_API_TOKEN=""

# ENCRYPTION (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=""

# FILE STORAGE
UPLOAD_DIR="./storage/uploads"
THUMBNAIL_DIR="./storage/thumbnails"
PREVIEW_DIR="./storage/previews"
TEMP_DIR="./storage/temp"
MAX_FILE_SIZE_MB="500"

# VECTOR EMBEDDINGS
EMBEDDING_PROVIDER="openai"
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIMENSIONS="1536"

# JOB QUEUE
JOB_QUEUE_MAX_CONCURRENT="3"
JOB_QUEUE_POLL_INTERVAL_MS="2000"
JOB_DEFAULT_TIMEOUT_MS="300000"
JOB_MAX_RETRIES="3"

# RATE LIMITING
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="60"
RATE_LIMIT_GENERATION_MAX="10"

# SOCIAL PUBLISHING
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
INSTAGRAM_APP_ID=""
INSTAGRAM_APP_SECRET=""

# MEDIA PROCESSING
FFMPEG_PATH="/usr/bin/ffmpeg"
FFPROBE_PATH="/usr/bin/ffprobe"
THUMBNAIL_WIDTH="400"
THUMBNAIL_HEIGHT="400"
THUMBNAIL_QUALITY="80"

# APP
NODE_ENV="development"
APP_PORT="3002"
LOG_LEVEL="info"
SENTRY_DSN=""
